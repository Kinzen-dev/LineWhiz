# ===========================================
# LineWhiz — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ----- Required: LINE API Credentials -----
# Get these from https://developers.line.biz/
# Create a Messaging API channel → Basic settings
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# ----- Required: LineWhiz Settings -----
# Tier: free / pro / business (MVP: hardcoded, v1.1: DB-backed)
LINEWHIZ_TIER=pro
LINEWHIZ_DATABASE_URL=sqlite:///linewhiz.db
LINEWHIZ_LOG_LEVEL=INFO

# ----- Optional: Rate Limiting -----
LINEWHIZ_RATE_LIMIT_WINDOW=86400

# ----- Optional: Billing (Stripe, v2.0+) -----
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
